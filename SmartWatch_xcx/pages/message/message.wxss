/* pages/message/message.wxss */
.container {
  background: #f5f7fa;
  min-height: 100vh;
  position: relative;
  padding-bottom: 20px;
}

.msg-list {
  height: 100vh;
  padding: 12px 16px;
  box-sizing: border-box;
}

.date-tag {
  text-align: center;
  margin: 16px 0 12px;
  font-size: 12px;
  color: #94a3b8;
  background: rgba(255,255,255,0.8);
  display: inline-block;
  padding: 4px 16px;
  border-radius: 30px;
  align-self: center;
  margin-left: auto;
  margin-right: auto;
}

.msg-item {
  margin-bottom: 16px;
}

.msg-time {
  font-size: 11px;
  color: #94a3b8;
  margin-bottom: 4px;
  margin-left: 8px;
}

.msg-bubble {
  max-width: 85%;
  padding: 12px 16px;
  border-radius: 18px;
  background: white;
  box-shadow: 0 2px 6px rgba(0,0,0,0.04);
  display: inline-block;
}

.msg-bubble.alert {
  background: #fee2e2;
  border-left: 4px solid #ef4444;
}

.msg-bubble.normal {
  background: #ffffff;
}

.msg-content {
  font-size: 15px;
  color: #1e293b;
  line-height: 1.5;
}

.empty-tip {
  text-align: center;
  color: #94a3b8;
  margin-top: 80px;
  font-size: 14px;
}

.float-btn {
  position: fixed;
  bottom: 30px;
  right: 20px;
  width: 56px;
  height: 56px;
  background: white;
  border: 1px solid #ffffff;
  border-radius: 28px;
  /* box-shadow: 0 6px 16px rgba(245, 87, 108, 0.3); */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.add-icon {
  width: 28px;
  height: 28px;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 24px 24px 0 0;
  padding: 24px 20px 30px;
  z-index: 101;
}

.modal-title {
  font-size: 18px;
  font-weight: bold;
  color: #1e293b;
  margin-bottom: 20px;
  text-align: center;
}

.modal-input {
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 14px 16px;
  font-size: 16px;
  margin-bottom: 24px;
  width: 100%;
  box-sizing: border-box;
}

.modal-btns {
  display: flex;
  gap: 12px;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  border-radius: 30px;
  padding: 14px 0;
  font-size: 16px;
}

.btn-cancel {
  background: #f1f5f9;
  color: #64748b;
}

.btn-confirm {
  background: #f5576c;
  color: white;
}
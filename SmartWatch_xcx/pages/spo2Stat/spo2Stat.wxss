page {
  background-color: #f8f9fc;
}

.page {
  padding-bottom: 60rpx;
}

/* 顶部渐变区 */
.hero {
  background: linear-gradient(135deg, #f5576c, #f093fb);
  padding: 60rpx 40rpx 80rpx;
  border-radius: 0 0 48rpx 48rpx;
  color: white;
  text-align: center;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 300;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.hero-value {
  font-size: 96rpx;
  font-weight: bold;
  margin-top: 20rpx;
  line-height: 1.2;
}

.hero-unit {
  font-size: 36rpx;
  font-weight: normal;
  margin-left: 8rpx;
}

.hero-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-top: 16rpx;
}

/* 图表卡片 */
.chart-card {
  margin: -40rpx 30rpx 30rpx;
  background-color: white;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.card-header {
  padding: 30rpx 30rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.card-header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e2a3e;
}

.card-header-date {
  font-size: 24rpx;
  color: #94a3b8;
}

.chart-container {
  position: relative;
  padding: 20rpx 20rpx 30rpx;
  min-height: 460rpx;
}

.chart {
  width: 100%;
  height: 460rpx;
}

.no-data {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  color: #94a3b8;
  font-size: 28rpx;
}

/* 统计卡片行 */
.stats-row {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  background-color: white;
  border-radius: 28rpx;
  padding: 32rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(0,0,0,0.03);
}

.stat-label {
  font-size: 28rpx;
  color: #64748b;
  display: block;
  margin-bottom: 16rpx;
}

.stat-value {
  font-size: 52rpx;
  font-weight: bold;
  color: #1e2a3e;
}

.stat-unit {
  font-size: 28rpx;
  font-weight: normal;
  color: #94a3b8;
  margin-left: 6rpx;
}

/* 按钮 */
.btn-wrapper {
  padding: 0 30rpx;
}

.refresh-btn {
  background: linear-gradient(135deg, #3b82f6, #06b6d4);
  color: white;
  border-radius: 60rpx;
  font-size: 32rpx;
  font-weight: 500;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  box-shadow: 0 8rpx 20rpx rgba(59,130,246,0.3);
  border: none;
}


.refresh-btn::after {
  border: none;
}
<view class="page">
  <view class="hero" style="background: linear-gradient(135deg, #f97316, #facc15);">
    <view class="hero-title">体温</view>
    <view class="hero-subtitle">最近100条记录</view>
    <view class="hero-value">{{avgTemp}}<text class="hero-unit">°C</text></view>
    <view class="hero-label">平均体温</view>
  </view>

  <view class="chart-card">
    <view class="card-header">
      <text class="card-header-title">体温变化趋势</text>
      <text class="card-header-date">近100次测量</text>
    </view>
    <view class="chart-container">
      <canvas canvas-id="tempChart" class="chart"></canvas>
      <view wx:if="{{!hasData}}" class="no-data">暂无体温数据</view>
    </view>
  </view>

  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-label">最高体温</text>
      <text class="stat-value">{{maxTemp}}<text class="stat-unit">°C</text></text>
    </view>
    <view class="stat-card">
      <text class="stat-label">最低体温</text>
      <text class="stat-value">{{minTemp}}<text class="stat-unit">°C</text></text>
    </view>
  </view>

  <view class="btn-wrapper">
    <button class="refresh-btn" bindtap="loadHistoryData" disabled="{{loading}}">
      {{loading ? '加载中...' : '刷新数据'}}
    </button>
  </view>
</view>